{
  "name": "@infolog24/root",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "db:generate": "pnpm --filter @infolog24/web drizzle-kit generate",
    "db:migrate": "pnpm --filter @infolog24/web drizzle-kit migrate",
    "db:studio": "pnpm --filter @infolog24/web drizzle-kit studio",
    "db:seed": "turbo run db:seed --filter=web"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "turbo": "^2",
    "vercel": "^50.43.0",
    "vitest": "^4.1.4"
  }
}
